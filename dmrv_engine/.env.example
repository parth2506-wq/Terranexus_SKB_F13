# ─── Sentinel Hub (OAuth2) ────────────────────────────────────────────
# Register: https://www.sentinel-hub.com/
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# ─── Copernicus Data Space (for TROPOMI S5P) ──────────────────────────
# Register: https://dataspace.copernicus.eu/
COPERNICUS_USER=
COPERNICUS_PASSWORD=

# ─── HTTP behaviour ───────────────────────────────────────────────────
HTTP_TIMEOUT_S=30
HTTP_RETRIES=3
HTTP_BACKOFF_S=1.5

# ─── Operational ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
CACHE_DIR=./.cache
ENVIRONMENT=development

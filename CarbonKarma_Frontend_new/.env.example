# CarbonKarma Frontend — Environment Variables
# Copy this to .env and fill in your values

# Backend API URL (empty = use Vite proxy to localhost:5000)
VITE_API_URL=

# Or point directly to your backend:
# VITE_API_URL=http://localhost:5000

# For production deployment:
# VITE_API_URL=https://your-backend-domain.com

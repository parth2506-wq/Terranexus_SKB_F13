# ─────────────────────────────────────────────────────────────
# CarbonKarma dMRV Platform — Environment Configuration
# Part 1 + Part 2
# Copy to .env and fill in your values before running.
# ─────────────────────────────────────────────────────────────

# ── Flask ──────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# ── Satellite data ─────────────────────────────────────────────
# Set to false to call live Open-Meteo ERA5 weather API (no key needed)
USE_MOCK_WEATHER=true

# Sentinel Hub credentials (optional — simulated if not set)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# ── Geospatial ─────────────────────────────────────────────────
DEFAULT_SPATIAL_RESOLUTION=10
DEFAULT_TEMPORAL_DAYS=90
# Simulated patch size in pixels (64 = 64×64 pixel field image)
PATCH_SIZE=64

# ── AI Models ──────────────────────────────────────────────────
MODEL_DEVICE=cpu               # cpu | cuda | mps
LSTM_HIDDEN_SIZE=64
LSTM_NUM_LAYERS=2
CNN_OUT_FEATURES=32

# ── Methane science ────────────────────────────────────────────
# Thresholds in mg CH4 / m² / day
METHANE_LOW_THRESHOLD=150
METHANE_HIGH_THRESHOLD=350
AWD_FLOOD_THRESHOLD=0.55       # water_prob above this = flooded
AWD_DRY_THRESHOLD=0.25         # water_prob below this = dry
AWD_MIN_CYCLE_DAYS=5           # minimum dry period for an AWD cycle

# ── Carbon credits ─────────────────────────────────────────────
CREDIT_PRICE_USD=15.0          # USD per tCO2e
# IPCC AR6 GWP-100 for CH4 is 27.9 (do not change without scientific basis)
# Conventional flooded paddy baseline: 480 kg CH4/ha/season
BASELINE_EMISSION_KG_HA=480.0

# ── LLM (OpenRouter) ───────────────────────────────────────────
# Get a free key at https://openrouter.ai
# If empty, template-based responses are used (fully functional)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# ── Farm profile defaults ──────────────────────────────────────
FARMER_NAME=Ravi Kumar
FARM_LOCATION=Thanjavur, Tamil Nadu, India
FARM_AREA_HA=4.5
CROP_TYPE=IR64 Paddy
SEASON=Kharif 2025
FARM_LAT=10.7867
FARM_LON=79.1378
IRRIGATION_SOURCE=Canal + Groundwater
SOIL_TYPE=Clay loam

# ── Report output ──────────────────────────────────────────────
REPORT_OUTPUT_DIR=./reports

# ── Verification thresholds ────────────────────────────────────
VERIFICATION_NDVI_MIN=0.25
VERIFICATION_TEMP_MAX_C=45.0
VERIFICATION_CLOUD_MAX=0.40

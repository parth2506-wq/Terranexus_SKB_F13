FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# Open-Meteo API (free, no key required — set USE_MOCK_WEATHER=false to use live)
USE_MOCK_WEATHER=true

# Sentinel Hub (optional — mocked if not set)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# Geospatial defaults
DEFAULT_SPATIAL_RESOLUTION=10
DEFAULT_TEMPORAL_DAYS=90

# Model settings
MODEL_DEVICE=cpu
LSTM_HIDDEN_SIZE=64
LSTM_NUM_LAYERS=2
CNN_OUT_FEATURES=32
